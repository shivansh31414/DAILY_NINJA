# Configuration Environment Variables
# Copy to .env and update values. DO NOT commit .env to git!

ENV=development
DEBUG=false
LOG_LEVEL=INFO

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=5000
SECRET_KEY=dev-secret-key-change-in-production
JWT_SECRET_KEY=jwt-secret-key-change-in-production

# Database (SQLite for dev, PostgreSQL/Azure for prod)
DATABASE_URL=sqlite:///daily_ninja.db
# PostgreSQL: postgresql://user:password@localhost:5432/daily_ninja
# Azure SQL: mssql+pyodbc://user:password@server.database.windows.net/db?driver=ODBC+Driver+18+for+SQL+Server

# Redis (optional)
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379

# Celery (optional)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Frontend
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=8501

# API URLs
API_BASE_URL=http://localhost:5000
FRONTEND_BASE_URL=http://localhost:8501
ALLOWED_ORIGINS=http://localhost:8501,http://localhost:3000

# JWT
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Optional: Azure
# AZURE_SUBSCRIPTION_ID=your-subscription-id
# AZURE_RESOURCE_GROUP=your-resource-group
# AZURE_STORAGE_ACCOUNT=your-storage-account

# Optional: Email
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
