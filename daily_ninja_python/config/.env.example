# Configuration Environment Variables
# Copy to .env and update values. DO NOT commit .env to git!

ENV=development
DEBUG=false
LOG_LEVEL=INFO
FLASK_ENV=development
PORT=5000

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=5000
SECRET_KEY=replace-with-strong-secret
JWT_SECRET_KEY=replace-with-strong-jwt-secret

# Database (SQLite for dev, PostgreSQL/Azure for prod)
DATABASE_URL=sqlite:///daily_ninja.db
# PostgreSQL: postgresql://user:password@localhost:5432/daily_ninja
# Azure SQL: mssql+pyodbc://user:password@server.database.windows.net/db?driver=ODBC+Driver+18+for+SQL+Server

# Redis (optional)
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379

# Celery (optional)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Frontend
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=8501

# API URLs
API_BASE_URL=http://localhost:5000
FRONTEND_BASE_URL=http://localhost:8501
ALLOWED_ORIGINS=http://localhost:8501,http://localhost:3000
CORS_ORIGINS=http://localhost:8501,http://localhost:3000

# JWT
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Optional: Azure
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZURE_RESOURCE_GROUP=daily-ninja-rg
AZURE_STORAGE_ACCOUNT=dailyninjastorage
AZURE_WEBAPP_NAME=daily-ninja-app
AZURE_APP_SERVICE_PLAN=daily-ninja-plan
ACR_NAME=dailyninjaacr
ACR_LOGIN_SERVER=dailyninjaacr.azurecr.io
KEY_VAULT_NAME=daily-ninja-kv
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=replace-me;IngestionEndpoint=https://example.in.applicationinsights.azure.com/

# Key Vault secret URIs for App Service references
KV_SECRET_KEY_URI=https://daily-ninja-kv.vault.azure.net/secrets/SECRET_KEY/
KV_JWT_SECRET_KEY_URI=https://daily-ninja-kv.vault.azure.net/secrets/JWT_SECRET_KEY/
KV_DATABASE_URL_URI=https://daily-ninja-kv.vault.azure.net/secrets/DATABASE_URL/

# Optional: Email
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
