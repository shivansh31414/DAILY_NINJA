# Daily Ninja Backend Environment Variables
# Copy this to .env and fill in your values

# Flask
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here
FLASK_ENV=development

# Database (Azure SQL example)
# DATABASE_URL=mssql+pyodbc://username:password@server.database.windows.net/dbname?driver=ODBC+Driver+18+for+SQL+Server

# For local development (SQLite)
DATABASE_URL=sqlite:///daily_ninja.db

# Server
PORT=5000
