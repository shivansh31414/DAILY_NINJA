# Backend Environment Variables
# Copy to .env and update values. DO NOT commit .env to git!

# Generate secure keys: python -c "import secrets; print(secrets.token_urlsafe(32))"
FLASK_ENV=development
SECRET_KEY=dev-secret-key-change-in-production
JWT_SECRET_KEY=jwt-secret-key-change-in-production

# Database (SQLite for dev, PostgreSQL/Azure SQL for prod)
DATABASE_URL=sqlite:///daily_ninja.db
# PostgreSQL: postgresql://user:password@localhost:5432/daily_ninja
# Azure SQL: mssql+pyodbc://user:password@server.database.windows.net/db?driver=ODBC+Driver+18+for+SQL+Server

PORT=5000
LOG_LEVEL=INFO
GUNICORN_WORKERS=4

# Optional: Redis & Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

CORS_ORIGINS=*
MAX_TASKS_PER_USER=100

# Docker Compose
DATABASE_USER=daily_ninja
DATABASE_PASSWORD=devpassword
DATABASE_NAME=daily_ninja
ENV=development
